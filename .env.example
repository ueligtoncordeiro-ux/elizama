# ─────────────────────────────────────────────
# CREDENCIAIS MERCADO PAGO
# Obter em: https://www.mercadopago.com.br/developers/panel/app
# Use credenciais de TESTE primeiro (sandbox), depois troque para PRODUÇÃO.
# ─────────────────────────────────────────────

# Access Token (NUNCA expor no frontend)
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000

# Public Key (pode ir no frontend, se usar Bricks/SDK JS)
MP_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000

# Secret do Webhook (Painel MP > Suas integrações > Webhooks > Configurar notificações)
MP_WEBHOOK_SECRET=

# URL base do site publicado (sem barra no final)
SITE_URL=https://elizama.vercel.app

# ─────────────────────────────────────────────
# SUPABASE (recomendado — persistência das doações)
# Obter em: https://app.supabase.com/project/_/settings/api
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
